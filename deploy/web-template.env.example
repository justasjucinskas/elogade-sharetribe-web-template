# Runtime environment for the container on the VM.
# Copy to `web-template.env` next to docker-compose.yml and fill in real values.
# Keep this file root-owned and chmod 600 — it holds secrets.
#
# NOTE: REACT_APP_* values are also baked into the client bundle at BUILD time
# (via GitHub Actions build-args). The ones repeated here are the subset the
# Express SERVER also reads at runtime, so they must match the build-time values.

# --- Required: Sharetribe Marketplace API ---
REACT_APP_SHARETRIBE_SDK_CLIENT_ID=   # public client id (also baked at build time)
SHARETRIBE_SDK_CLIENT_SECRET=         # SECRET — runtime only, never baked. Required for /api/*-privileged

# --- Required: public site URL + branding ---
REACT_APP_MARKETPLACE_ROOT_URL=https://yourdomain.com   # must match the public URL Caddy serves
REACT_APP_MARKETPLACE_NAME=

# --- Payments / maps (publishable, also baked at build time) ---
REACT_APP_STRIPE_PUBLISHABLE_KEY=
REACT_APP_MAPBOX_ACCESS_TOKEN=

# --- Social login (optional) ---
REACT_APP_FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=                  # SECRET — runtime only
REACT_APP_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=                 # SECRET — runtime only

# --- Server behaviour ---
PORT=3000
REACT_APP_ENV=production
REACT_APP_CSP=report                  # 'block' to enforce CSP once verified

# --- Behind Caddy (TLS terminated by the proxy) ---
SERVER_SHARETRIBE_TRUST_PROXY=true    # trust X-Forwarded-* from Caddy
SERVER_SHARETRIBE_REDIRECT_SSL=true   # 301 http->https (safe once trust-proxy is set)
